{
  "name": "stellar-lens",
  "version": "0.1.0",
  "description": "Soroban transaction pre-flight simulation, smart RPC routing with latency-ranked automatic fallback, and human-readable XDR error decoding for the Stellar network.",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [],
  "author": "Ezedike-Evan <egwomevan323@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
